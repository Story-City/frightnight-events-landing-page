---
export interface Props {
  locationLabel?: string
  eventDateLabel?: string
  ticketHref?: string
  citySlug?: string
  heroFaded?: boolean
}

const { locationLabel = '', eventDateLabel = '', ticketHref = '', citySlug = '', heroFaded = false } = Astro.props

const ticketLinkAttrs = ticketHref.startsWith('http') ? ({ target: '_blank', rel: 'noopener noreferrer' } as const) : {}
const reviewsHref = citySlug ? `/${citySlug}/reviews` : '/reviews'
const homeHref = citySlug ? `/${citySlug}` : '/'
---

<nav id="top-nav" class="fixed top-0 left-0 right-0 z-40 transition-colors duration-300 font-hacked">
  <div class="max-w-6xl w-full mx-auto flex justify-between items-center px-5 py-2">
    <button
      id="hamburger-btn"
      type="button"
      aria-label="Open menu"
      aria-expanded="false"
      class="min-[700px]:hidden text-white p-2 -ml-2 cursor-pointer bg-transparent border-none"
    >
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="4" y1="7" x2="20" y2="7" />
        <line x1="4" y1="12" x2="20" y2="12" />
        <line x1="4" y1="17" x2="20" y2="17" />
      </svg>
    </button>
    <a href={homeHref} class="hidden min-[700px]:block text-white tracking-wide text-lg lg:text-xl font-hacked">FRIGHTNIGHT</a>
    <div class="flex items-center">
      <a href={reviewsHref} class="hidden min-[700px]:inline text-white tracking-wide text-base self-center mr-6 font-hacked">REVIEWS</a>
      <a href="#" data-faq-trigger class="hidden min-[700px]:inline text-white tracking-wide text-base self-center mr-6 font-hacked">MORE INFO</a>
      {
        ticketHref && (
          <a href={ticketHref} class="buy-tickets-btn block" {...ticketLinkAttrs}>
            <span class="buy-tickets-btn__fill bg-neon" aria-hidden="true" />
            <span class="buy-tickets-btn__text tracking-wide">BUY TICKETS</span>
          </a>
        )
      }
    </div>
  </div>
</nav>

<div id="mobile-menu" class="hidden fixed inset-0 z-50 bg-black/95 font-hacked">
  <div class="flex justify-end p-5">
    <button
      id="mobile-menu-close"
      type="button"
      aria-label="Close menu"
      class="text-white text-3xl cursor-pointer bg-transparent border-none p-2"
    >
      ✕
    </button>
  </div>
  <nav class="flex flex-col items-center gap-8 pt-8">
    <a href={homeHref} class="text-white tracking-wide text-3xl font-hacked">FRIGHTNIGHT</a>
    <a href={reviewsHref} class="text-white tracking-wide text-2xl font-hacked">REVIEWS</a>
    <a href="#" data-faq-trigger class="text-white tracking-wide text-2xl font-hacked">MORE INFO</a>
  </nav>
</div>

<div class:list={["hero-outer w-full min-h-[780px] lg:min-h-[850px] text-white font-hacked bg-black relative overflow-hidden", heroFaded && "hero-outer--faded"]}>
  <div
    class="hero-content flex flex-col w-full min-h-[780px] lg:min-h-[850px] relative pb-6 px-5 max-w-[1400px] mx-auto"
  >
    <div class="max-w-6xl w-full mx-auto grow flex flex-col relative z-10">
      <div class="h-16"></div>

      <div class="w-full h-full mt-auto lg:mb-18">
        <h1 class="text-6xl leading-tight text-white tracking-wide text-center lg:text-left">FRIGHTNIGHT</h1>
        <div class="flex flex-col lg:flex-row items-center justify-center lg:justify-between">
          {
            locationLabel && eventDateLabel && (
              <div class="text-2xl font-hacked lg:ml-6 leading-tight flex items-center">
                <span class="tracking-wide">{locationLabel}</span>
                <span class="mx-3">/</span>
                <span class="tracking-wide">{eventDateLabel}</span>
              </div>
            )
          }

          <h2 class="text-2xl tracking-wide font-compressed text-center lg:text-left text-pretty">
            Hunt ghosts. Survive hauntings. Save your city.
          </h2>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .hero-outer--faded .hero-content {
    opacity: 0.05;
  }

  .hero-content {
    background-blend-mode: darken;
    background:
      linear-gradient(
        356.33deg,
        rgba(255, 255, 255, 0) -29.82%,
        rgba(73, 75, 77, 0.714286) -19.96%,
        #000306 -10.39%,
        #000e1c 13.72%,
        #264d58 20.8%,
        rgba(0, 54, 108, 0) 28.76%
      ),
      linear-gradient(140.69deg, rgba(0, 0, 0, 0.58) 9.83%, rgba(0, 0, 0, 0) 30.13%), url('/bg.webp');
    background-size: cover;
    background-repeat: no-repeat;
    background-position-y: 10px;
    background-position-x: 59%;
    mask-image: linear-gradient(to right, transparent, black 3%, black 97%, transparent);
  }

  .hero-content::before {
    content: '';
    position: absolute;
    top: 10px;
    left: 0;
    right: 0;
    height: 20%;
    background: linear-gradient(to top, transparent, var(--color-black));
    pointer-events: none;
    z-index: 1;
  }

  .hero-content::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 30px;
    background: linear-gradient(to bottom, transparent, var(--color-black));
    pointer-events: none;
  }

  .headline-bg {
    background: linear-gradient(180deg, #33afc1 0%, #b4f4ff 100%);
    filter: blur(16px);
    border-radius: 560px;
    opacity: 0.31;
    width: 100%;
    height: 100%;
  }

  .buy-tickets-btn {
    padding: 10px 45px;
    box-sizing: border-box;
    position: relative;
    width: fit-content;
    text-decoration: none;
    margin-bottom: 0;
    margin-top: 0;
  }

  @media (min-width: 1024px) {
    .buy-tickets-btn {
      margin-bottom: 24px;
      margin-top: 16px;
    }
  }

  .buy-tickets-btn__fill {
    position: absolute;
    inset: 2px;
    clip-path: polygon(0 0, 90% 0, 100% 100%, 10% 100%);
    z-index: 0;
  }

  .buy-tickets-btn__text {
    position: relative;
    z-index: 1;
    display: inline-block;
    color: #000;
    font-size: 16px;
    line-height: 1.2;
    text-transform: uppercase;
    width: max-content;
  }
</style>

<script>
  const nav = document.getElementById('top-nav')
  if (nav) {
    window.addEventListener(
      'scroll',
      () => {
        if (window.scrollY > 50) {
          nav.style.backgroundColor = 'rgba(1, 9, 18, 0.85)'
        } else {
          nav.style.backgroundColor = 'transparent'
        }
      },
      { passive: true },
    )
  }

  const menu = document.getElementById('mobile-menu')
  const openBtn = document.getElementById('hamburger-btn')
  const closeBtn = document.getElementById('mobile-menu-close')
  const closeMenu = () => {
    menu?.classList.add('hidden')
    openBtn?.setAttribute('aria-expanded', 'false')
    document.body.style.overflow = ''
  }
  openBtn?.addEventListener('click', () => {
    menu?.classList.remove('hidden')
    openBtn.setAttribute('aria-expanded', 'true')
    document.body.style.overflow = 'hidden'
  })
  closeBtn?.addEventListener('click', closeMenu)
  menu?.querySelectorAll('a').forEach(a => a.addEventListener('click', closeMenu))
</script>
