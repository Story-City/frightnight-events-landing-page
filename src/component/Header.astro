---
export interface Props {
  locationLabel?: string
  eventDateLabel?: string
  ticketHref?: string
}

const { locationLabel = '', eventDateLabel = '', ticketHref = '' } = Astro.props

const ticketLinkAttrs = ticketHref.startsWith('http') ? ({ target: '_blank', rel: 'noopener noreferrer' } as const) : {}
---

<div class="w-full min-h-[640px] bg-cover bg-center text-white font-hacked">
  <div class="hero-content flex flex-col w-full min-h-[640px] relative py-6 px-5">
    <div class="max-w-6xl w-full mx-auto grow flex flex-col">
      <div class="flex justify-center lg:justify-end">
        {
          ticketHref && (
            <a href={ticketHref} class="buy-tickets-btn block" {...ticketLinkAttrs}>
              <span class="buy-tickets-btn__fill bg-neon" aria-hidden="true" />
              <span class="buy-tickets-btn__text tracking-wide">BUY TICKETS</span>
            </a>
          )
        }
        <a href="/FAQ" class="buy-tickets-btn block">
          <span class="buy-tickets-btn__fill bg-neon" aria-hidden="true"></span>
          <span class="buy-tickets-btn__text tracking-wide">FAQs</span>
        </a>
      </div>

      <div class="w-full h-full mt-auto lg:mb-18">
        <h1 class="text-4xl sm:text-6xl leading-tight text-white tracking-wide text-center lg:text-left">
          FRIGHTNIGHT
        </h1>
        <div class="flex flex-col lg:flex-row items-center justify-center lg:justify-between">
          {
            locationLabel && eventDateLabel && (
              <div class="text-2xl font-hacked lg:ml-6 leading-tight flex items-center">
                <span class="tracking-wide">{locationLabel}</span>
                <span class="mx-3">/</span>
                <span class="tracking-wide">{eventDateLabel}</span>
              </div>
            )
          }

          <h2 class="text-2xl tracking-wide font-compressed text-center lg:text-left text-pretty">
            Hunt ghosts. Survive hauntings. Save your city.
          </h2>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .hero-content {
    background-blend-mode: darken;
    background:
      linear-gradient(
        356.33deg,
        rgba(255, 255, 255, 0) -29.82%,
        rgba(73, 75, 77, 0.714286) -19.96%,
        #000306 -10.39%,
        #000e1c 13.72%,
        #264d58 20.8%,
        rgba(0, 54, 108, 0) 28.76%
      ),
      linear-gradient(140.69deg, rgba(0, 0, 0, 0.58) 9.83%, rgba(0, 0, 0, 0) 30.13%),
      url('/bg.webp') no-repeat center center / cover;
    background-size: cover;
    background-position-y: 50px;
    background-position-x: 100%;
  }

  .headline-bg {
    background: linear-gradient(180deg, #33afc1 0%, #b4f4ff 100%);
    filter: blur(16px);
    border-radius: 560px;
    opacity: 0.31;
    width: 100%;
    height: 100%;
  }

  .buy-tickets-btn {
    padding: 10px 60px;
    box-sizing: border-box;
    position: relative;
    width: fit-content;
    text-decoration: none;
    margin-bottom: 36px;
    margin-top: 24px;
  }

  .buy-tickets-btn__fill {
    position: absolute;
    inset: 2px;
    clip-path: polygon(0 0, 90% 0, 100% 100%, 10% 100%);
    z-index: 0;
  }

  .buy-tickets-btn__text {
    position: relative;
    z-index: 1;
    display: inline-block;
    color: #000;
    font-size: 16px;
    line-height: 1.2;
    text-transform: uppercase;
  }
</style>
