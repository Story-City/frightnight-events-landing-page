---
export interface Props {
  groupTicketPrice?: string
  soloTicketPrice?: string
  ticketSaleLink?: string
  soloTicketLink?: string
  soloTicketTitle?: string
  soloButtonLabel?: string
  groupTicketTitle?: string
  groupButtonLabel?: string
  bundleCopy?: string
  locationLabel?: string
}

const {
  groupTicketPrice = '$37.50',
  soloTicketPrice = '$30',
  ticketSaleLink = '#tickets',
  soloTicketLink,
  soloTicketTitle = 'Lone Hunter',
  soloButtonLabel = 'Buy Ticket',
  groupTicketTitle = 'Team Pass',
  groupButtonLabel = 'Buy Tickets',
  bundleCopy,
} = Astro.props

const groupLink = ticketSaleLink
const soloLink = soloTicketLink && soloTicketLink.trim() !== '' ? soloTicketLink : ticketSaleLink

const groupAttrs = groupLink.startsWith('http') ? { target: '_blank', rel: 'noopener noreferrer' } : {}
const soloAttrs = soloLink.startsWith('http') ? { target: '_blank', rel: 'noopener noreferrer' } : {}
---

<div class="w-full max-w-6xl mx-auto text-white font-hacked">
  <div class="bg-cyan/25 pr-4 max-w-[500px] ml-auto py-6 cta-wrapper lg:hidden flex">
    <div class="cta-content flex flex-col">
      <div>
        <div class="text-2xl leading-tight text-balance tracking-wide pl-16">
          <span class="glitch" data-text={soloTicketTitle}>{soloTicketTitle}</span>
        </div>
        <div class="flex items-center pl-22">
          <span class="text-[32px] leading-tight tracking-wide">{soloTicketPrice}</span>
        </div>
      </div>

      <a href={soloLink} class="ml-24 buy-tickets-btn block" {...soloAttrs}>
        <span class="buy-tickets-btn__fill bg-neon" aria-hidden="true"></span>
        <span class="buy-tickets-btn__text tracking-wide">{soloButtonLabel}</span>
      </a>
    </div>
  </div>

  <div class="bg-cyan/25 pr-4 max-w-[500px] ml-auto mt-6 py-6 cta-wrapper lg:hidden flex">
    <div class="cta-content flex flex-col">
      <div>
        <div class="text-2xl leading-tight text-balance tracking-wide pl-16">
          <span class="glitch" data-text={groupTicketTitle}>{groupTicketTitle}</span>
        </div>
        <div class="flex items-center pl-22">
          <span class="text-[32px] leading-tight tracking-wide">{groupTicketPrice}</span>
        </div>
        {bundleCopy && (
          <div class="pl-22 pr-2 text-base text-light-gray tracking-wide font-abeezee mt-1">{bundleCopy}</div>
        )}
      </div>

      <a href={groupLink} class="ml-24 buy-tickets-btn block" {...groupAttrs}>
        <span class="buy-tickets-btn__fill bg-neon" aria-hidden="true"></span>
        <span class="buy-tickets-btn__text tracking-wide">{groupButtonLabel}</span>
      </a>
    </div>
  </div>

  <div class="hidden lg:grid grid-cols-2 max-w-[1100px] ml-auto -translate-y-11 gap-6 pr-8">
    <div class="min-w-0 relative py-6 desktop-cta-card desktop-cta-card--solo">
      <div class="desktop-cta-card-clip bg-cyan/25 absolute inset-0"></div>
      <div class="desktop-cta-content relative flex items-center h-full pl-20">
        <div class="text-center mr-6">
          <div class="text-2xl leading-tight tracking-wide w-max">
            <span class="glitch" data-text={soloTicketTitle}>{soloTicketTitle}</span>
          </div>
          <div class="text-[32px] leading-tight tracking-wide">{soloTicketPrice}</div>
        </div>

        <a href={soloLink} class="buy-tickets-btn block w-max" {...soloAttrs}>
          <span class="buy-tickets-btn__fill bg-neon" aria-hidden="true"></span>
          <span class="buy-tickets-btn__text tracking-wide">{soloButtonLabel}</span>
        </a>
      </div>
    </div>

    <div class="min-w-0 relative py-6 desktop-cta-card desktop-cta-card--group">
      <div class="desktop-cta-card-clip bg-cyan/25 absolute inset-0"></div>
      <div class="desktop-cta-content relative flex items-center h-full pl-20">
        <div class="text-center mr-6">
          <div class="text-2xl leading-tight tracking-wide w-max">
            <span class="glitch" data-text={groupTicketTitle}>{groupTicketTitle}</span>
          </div>
          <div class="text-[32px] leading-tight tracking-wide">{groupTicketPrice}</div>
          {bundleCopy && (
            <div class="text-sm text-light-gray tracking-wide font-abeezee mt-1 w-max">{bundleCopy}</div>
          )}
        </div>

        <a href={groupLink} class="buy-tickets-btn block w-max" {...groupAttrs}>
          <span class="buy-tickets-btn__fill bg-neon" aria-hidden="true"></span>
          <span class="buy-tickets-btn__text tracking-wide">{groupButtonLabel}</span>
        </a>
      </div>
    </div>
  </div>
</div>

<style>
  .cta-wrapper {
    clip-path: polygon(0 0, 100% 0%, 100% 100%, 21% 100%);
  }

  .desktop-cta-card-clip {
    clip-path: polygon(0 0, 80% 0%, 100% 100%, 23% 100%);
  }

  .buy-tickets-btn {
    padding: 13px 60px;
    box-sizing: border-box;
    position: relative;
    width: fit-content;
    text-decoration: none;
    margin-top: 12px;
  }

  .buy-tickets-btn__fill {
    position: absolute;
    inset: 2px;
    clip-path: polygon(0 0, 90% 0, 100% 100%, 10% 100%);
    z-index: 0;
  }

  .buy-tickets-btn__text {
    position: relative;
    z-index: 1;
    display: inline-block;
    color: #000;
    font-size: 24px;
    line-height: 1.2;
    letter-spacing: 7%;
    text-transform: uppercase;
    white-space: nowrap;
  }

  @media (min-width: 1024px) {
    .buy-tickets-btn {
      margin-top: 0px;
      padding: 18px 70px;
      z-index: 2;
      width: max-content;
    }
    .desktop-cta-card .buy-tickets-btn {
      position: absolute;
      right: -42px;
      top: 50%;
      transform: translateY(-50%);
    }
    .buy-tickets-btn__fill {
      clip-path: polygon(0 0, 80% 0%, 100% 100%, 20% 100%);
    }
    .buy-tickets-btn__text {
      font-size: 24px;
    }
  }
</style>
