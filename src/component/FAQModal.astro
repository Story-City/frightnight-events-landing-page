---
import { formatEventDateLabel } from '../lib/formatEventDate'

export interface Props {
  locationTime: string
  eventDate: unknown
}

const { locationTime, eventDate } = Astro.props
const eventDateLabel = formatEventDateLabel(eventDate) || 'TBA'
---

<div id="faq-modal" class="hidden fixed inset-0 z-70">
  <div id="faq-backdrop" class="absolute inset-0 bg-black/80"></div>
  <div class="absolute inset-0 overflow-y-auto">
    <div class="max-w-4xl mx-auto py-12 px-6 relative">
      <button
        id="faq-close"
        class="sticky top-4 float-right text-light-gray text-3xl font-hacked cursor-pointer bg-transparent border-none z-10"
      >
        ✕
      </button>
      <h1 class="text-4xl leading-tight text-light-gray tracking-wide font-hacked mb-4">More Info</h1>

      <div class="bg-black/85 rounded-lg p-5 mb-4">
        <h2 class="text-2xl leading-tight text-light-gray tracking-wide font-hacked mb-3">What You Need to Know</h2>
        <ul class="text-lg text-light-gray tracking-wide font-abeezee list-disc pl-5 space-y-2">
          <li>A 45-75min walkable event experience.</li>
          <li><strong>Hunt ghosts at real locations</strong> - uncover eerie stories at multiple locales.</li>
          <li><strong>Bring a charged phone</strong> - to follow clues, track signals, and capture paranormal photos.</li>
          <li><strong>Your choices your ending</strong> - every decision changes your route, points, and ghost encounters.</li>
          <li><strong>Your team can be any size</strong> - immense fun for couples, families, or multiplayer teams.</li>
        </ul>
      </div>

      <div class="bg-black/85 rounded-lg p-5 mb-4">
        <h2 class="text-2xl leading-tight text-light-gray tracking-wide font-hacked mb-3">Event Details</h2>
        <img
          src="/CYE_v2.webp"
          alt="Choose Your Ending experience flowchart"
          class="w-full h-auto rounded mb-4"
          loading="lazy"
          decoding="async"
        />
        <p class="text-lg text-light-gray tracking-wide font-abeezee mb-3">
          Imagine this experience overlaid on your city streets, where each stop happens in a new location. One start
          location, multiple potential paths, 4 endings. Which will you choose?
        </p>
        <ol class="text-lg text-light-gray tracking-wide font-abeezee list-decimal pl-5 space-y-2">
          <li><strong>Grab your ticket</strong> - play solo or as a team (no ghost-hunting alone required). Ticket sales end April 28th!</li>
          <li><strong>Get your secret start location</strong> - revealed by email 1 week before</li>
          <li><strong>Show up & start</strong> - anytime on event day between {locationTime}, dress to impress!</li>
          <li><strong>Live Photographer</strong> - on-site at the start location (4-6pm) to capture your moment</li>
          <li><strong>Play the adventure</strong> - The experience unfolds via our custom built app - guiding you from location to location, keeping track of your points, and making the ghosts visible.</li>
          <li><strong>Take your time</strong> - most teams finish in 45–75 mins</li>
          <li><strong>Make your choices</strong> - stick together or split up to unlock up to 4 different endings</li>
          <li><strong>Share the moment</strong> - share your photos of ghost encounters & costumes to win prizes</li>
          <li><strong>(BONUS) Play again</strong> - unlock every haunting, badge and ending with unlimited replays</li>
        </ol>
      </div>

      <div class="bg-black/85 rounded-lg p-5 mb-4">
        <h2 class="text-2xl leading-tight text-light-gray tracking-wide font-hacked mb-3">
          How Scary is it & Other FAQs
        </h2>
        <p class="text-lg text-light-gray tracking-wide font-abeezee mb-3">
          Scare rating <span class="text-neon">★★</span><span class="text-neon/25">☆☆☆</span>
        </p>
        <ul class="text-lg text-light-gray tracking-wide font-abeezee list-disc pl-5 space-y-2">
          <li><strong>“Is it scary?”</strong> It’s atmospheric and thrilling, designed for mystery lovers. There are no live scare actors present to jump out or grab you.</li>
          <li><strong>“Do I dress up?”</strong> You can! Dress up to win prizes - gothic glam or investigator chic</li>
          <li><strong>“Can I bring pets?”</strong> Yes! Your furry sidekick is welcome.</li>
          <li><strong>"What if it rains?"</strong> The hunt continues! If the weather is severe, we’ll automatically credit your account for a future date of your choice.</li>
          <li><strong>“Are there age restrictions?”</strong> Children and strollers are welcome, content rating is PG-13+, we recommend 13+ mostly due to experience length and walking distance for children.</li>
        </ul>
      </div>

      <div class="bg-black/85 rounded-lg p-5 mb-4">
        <h2 class="text-2xl leading-tight text-light-gray tracking-wide font-hacked mb-3">Prizes</h2>
        <p class="text-lg text-light-gray tracking-wide font-abeezee mb-3">
          We LOVE when teams dress up and bring their ghost-hunting alter-egos to life. Share photos using
          #StoryCityFrightnight to enter:
        </p>
        <ul class="text-lg text-light-gray tracking-wide font-abeezee list-disc pl-5 space-y-2">
          <li>🏆 Best Dressed Team</li>
          <li>✨ Best Dressed Individual</li>
          <li>⚡ Best Day of Ghost Story TikTok</li>
          <li>📝 Best Team Name</li>
          <li>📸 Best Photo Moment</li>
          <li>🐾 Best Themed Pet</li>
        </ul>
        <p class="text-lg text-light-gray tracking-wide font-abeezee mt-3">
          Winners receive cash prizes (up to $500 depending on the category), exclusive enamel pins, creator-signed art,
          and more, plus a feature on our socials.
        </p>
        <p class="text-lg text-light-gray tracking-wide font-abeezee mt-3">
          You'll be battling events in other cities for the top spots so bring your A-game and city pride!
        </p>
      </div>

      <div class="bg-black/85 rounded-lg p-5 mb-4">
        <h2 class="text-2xl leading-tight text-light-gray tracking-wide font-hacked mb-3">About Story City</h2>
        <div class="text-lg text-light-gray tracking-wide font-abeezee space-y-3">
          <p>
            Story City is a small, independent, 10-person creative-tech studio on a mission: To empower people to share
            and step into the world's stories.
          </p>
          <p>
            Our no-code platform has helped 200+ creators turn real streets into playable storyworlds - stories you can
            step inside, explore, and change through your choices.
          </p>
          <p>
            We have partnered with festivals, museums, cities (eg. City of Atlanta, Calgary, Melbourne UNESCO City),
            non-profits (eg. Human Rights Foundation), and creators around the world.
          </p>
          <p>
            By purchasing a ticket, you help bring more independently created stories to communities like yours. Thank
            you for co-creating with us to make the world more fun and connected.
          </p>
          <p>
            Big shout out to the creators of this experience: Domini Gee (Writer), Emily Craven (Writer/Producer), Matt
            Mihilewicz (Editor/VO Director), Victoria Ilnystka (Artist), Lauren Hughes (Actor), Toast + Jam/Jeremy
            Volts/Aaron Jensen (Music & sound).
          </p>
        </div>
      </div>

      <div class="bg-black/85 rounded-lg p-5 mb-4">
        <h2 class="text-2xl leading-tight text-light-gray tracking-wide font-hacked mb-3">Ticket Info</h2>
        <ul class="text-lg text-light-gray tracking-wide font-abeezee list-disc pl-5 space-y-2">
          <li>Single or Team Ticket available (More people - Better value!)</li>
          <li>Date: {eventDateLabel}</li>
          <li>Purchase Tickets By: April 28th</li>
          <li>Start anytime between {locationTime} event day</li>
          <li>👟 Walking: ~1-1.5 miles</li>
          <li>Phone OS: You need at minimum iOS 16 or Android 7</li>
          <li>
            A shareable link is given in the pre-event email so every team member can access their ticket and play from
            their own device
          </li>
          <li>Headphones or Bluetooth speaker are recommended for spooky immersion!</li>
          <li>All tickets are digitally delivered to your purchasing email</li>
        </ul>
      </div>

      <div class="bg-black/85 rounded-lg p-5 mb-4">
        <h2 class="text-2xl leading-tight text-light-gray tracking-wide font-hacked mb-3">Safety</h2>
        <p class="text-lg text-light-gray tracking-wide font-abeezee mb-3">Our adventures are:</p>
        <ul class="text-lg text-light-gray tracking-wide font-abeezee list-disc pl-5 space-y-2">
          <li>Outdoors and naturally socially distanced (if you need!)</li>
          <li>Flexible - pause anytime, continue at your pace</li>
          <li>Designed to be stroller and wheelchair friendly where possible</li>
          <li>If your pre-event route email shows the terrain will not meet your needs, we will refund you.</li>
          <li>
            Your location is only tracked while using the app to unlock experience content tied to specific locations.
          </li>
        </ul>
      </div>
    </div>
  </div>
</div>

<script>
  const modal = document.getElementById('faq-modal')!
  const backdrop = document.getElementById('faq-backdrop')!
  const closeBtn = document.getElementById('faq-close')!

  document.querySelectorAll('[data-faq-trigger]').forEach(el => {
    el.addEventListener('click', e => {
      e.preventDefault()
      modal.classList.remove('hidden')
      document.body.style.overflow = 'hidden'
    })
  })

  function close() {
    modal.classList.add('hidden')
    document.body.style.overflow = ''
  }

  closeBtn.addEventListener('click', close)
  backdrop.addEventListener('click', close)
</script>
