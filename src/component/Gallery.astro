---
import { Image } from 'astro:assets'
import type { ImageMetadata } from 'astro'

export interface Props {
  title: string
  description: string
}

const { title, description } = Astro.props

const imageModules = import.meta.glob<{ default: ImageMetadata }>('./gallery/*.webp', { eager: true })
const videoModules = import.meta.glob<{ default: string }>('./gallery/*.webm', { eager: true, import: 'default' })

type Slide = { kind: 'image'; src: ImageMetadata } | { kind: 'video'; src: string }

const slides: Slide[] = [
  ...Object.keys(imageModules).map(path => ({ kind: 'image' as const, src: imageModules[path].default, path })),
  ...Object.keys(videoModules).map(path => ({
    kind: 'video' as const,
    src: videoModules[path] as unknown as string,
    path,
  })),
]
  .sort((a, b) => a.path.localeCompare(b.path, undefined, { numeric: true }))
  .map(({ kind, src }) => ({ kind, src }) as Slide)
---

{
  slides.length > 0 && (
    <section class="gallery-section w-full bg-black text-white relative overflow-hidden" data-gallery>
      <div class="gallery-shapes" aria-hidden="true">
        <div class="gallery-shape gallery-shape--1 bg-neon/20" />
      </div>

      <div class="gallery-panel relative z-1 px-5 py-12 md:py-16">
        <div class="gallery-inner mt-4 max-w-3xl mx-auto flex flex-col items-center text-center">
          <h2 class="font-hacked text-2xl md:text-3xl tracking-wide uppercase mb-4 text-pretty">{title}</h2>
          <p class="font-abeezee text-base md:text-lg text-white/90 max-w-xl mb-8 text-pretty leading-snug">
            {description}
          </p>

          <div class="gallery-viewport-wrapper relative w-full">
            <div class="gallery-viewport relative w-full aspect-1080/1350 max-h-[70vh] overflow-hidden bg-black/40">
              {slides.map((slide, i) => (
                <div
                  class:list={[
                    'gallery-slide absolute inset-0 transition-opacity duration-300',
                    i === 0 ? 'gallery-slide--active opacity-100 z-1' : 'opacity-0 z-0 pointer-events-none',
                  ]}
                  data-gallery-slide
                  aria-hidden={i === 0 ? 'false' : 'true'}
                >
                  {slide.kind === 'image' ? (
                    <Image
                      src={slide.src}
                      alt={`${title} — slide ${i + 1} of ${slides.length}`}
                      class="w-full h-full object-cover"
                      width={1080}
                      height={1350}
                      sizes="(min-width: 768px) 48rem, 100vw"
                      loading={i === 0 ? 'eager' : 'lazy'}
                      decoding="async"
                    />
                  ) : (
                    <video src={slide.src} class="w-full h-full object-cover" playsinline muted loop data-gallery-video>
                      <track kind="descriptions" label={`${title} — slide ${i + 1} of ${slides.length}`} />
                    </video>
                  )}
                </div>
              ))}
            </div>

            {slides.length > 1 && (
              <>
                <button
                  type="button"
                  class="gallery-arrow gallery-arrow--prev"
                  data-gallery-prev
                  aria-label="Previous slide"
                >
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path d="M15 6l-6 6 6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </button>
                <button
                  type="button"
                  class="gallery-arrow gallery-arrow--next"
                  data-gallery-next
                  aria-label="Next slide"
                >
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path d="M9 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </button>
              </>
            )}
          </div>

          <div class="gallery-dots flex flex-wrap justify-center gap-3 mt-6" role="tablist" aria-label="Gallery slides">
            {slides.map((_, i) => (
              <button
                type="button"
                class="gallery-dot h-2.5 w-2.5 rounded-full transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-neon focus-visible:ring-offset-2 focus-visible:ring-offset-black"
                data-gallery-dot
                role="tab"
                aria-selected={i === 0 ? 'true' : 'false'}
                aria-label={`Show slide ${i + 1} of ${slides.length}`}
                tabindex={i === 0 ? 0 : -1}
              />
            ))}
          </div>
        </div>
      </div>
    </section>
  )
}

<script is:inline>
  document.querySelectorAll('[data-gallery]').forEach(function (root) {
    var slides = root.querySelectorAll('[data-gallery-slide]')
    var dots = root.querySelectorAll('[data-gallery-dot]')
    if (!slides.length || !dots.length) return

    function syncVideos() {
      slides.forEach(function (slide) {
        var video = slide.querySelector('[data-gallery-video]')
        if (!video) return
        var active = slide.classList.contains('gallery-slide--active')
        if (active) {
          video.play().catch(function () {})
        } else {
          video.pause()
        }
      })
    }

    var current = 0

    function goTo(index) {
      current = Math.max(0, Math.min(index, slides.length - 1))
      slides.forEach(function (slide, idx) {
        var active = idx === current
        slide.classList.toggle('gallery-slide--active', active)
        slide.classList.toggle('opacity-100', active)
        slide.classList.toggle('z-1', active)
        slide.classList.toggle('opacity-0', !active)
        slide.classList.toggle('z-0', !active)
        slide.classList.toggle('pointer-events-none', !active)
        slide.setAttribute('aria-hidden', active ? 'false' : 'true')
      })
      dots.forEach(function (dot, idx) {
        var active = idx === current
        dot.setAttribute('aria-selected', active ? 'true' : 'false')
        dot.tabIndex = active ? 0 : -1
      })
      syncVideos()
    }

    dots.forEach(function (dot, i) {
      dot.addEventListener('click', function () {
        goTo(i)
      })
    })

    var prevBtn = root.querySelector('[data-gallery-prev]')
    var nextBtn = root.querySelector('[data-gallery-next]')

    if (prevBtn) {
      prevBtn.addEventListener('click', function () {
        goTo(current <= 0 ? slides.length - 1 : current - 1)
      })
    }
    if (nextBtn) {
      nextBtn.addEventListener('click', function () {
        goTo(current >= slides.length - 1 ? 0 : current + 1)
      })
    }

    syncVideos()
  })
</script>

<style>
  /* Decorative angular shapes — desktop only */
  .gallery-shapes {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  .gallery-shape--1 {
    position: absolute;
    top: 50px;
    left: 50%;
    transform: translateX(-50%);
    width: clamp(1100px, 120%, 120%);
    height: 550px;
    clip-path: polygon(20% 0, 100% 0%, 80% 100%, 0% 100%);
  }

  /* Arrow buttons */
  .gallery-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border: none;
    border-radius: 50%;
    background: rgba(0, 0, 0, 0.55);
    color: #fff;
    cursor: pointer;
    transition: background-color 0.2s, color 0.2s;
  }
  .gallery-arrow:hover {
    background: var(--color-neon);
    color: #000;
  }
  .gallery-arrow:focus-visible {
    outline: none;
    box-shadow: 0 0 0 2px var(--color-neon), 0 0 0 4px #000;
  }
  .gallery-arrow--prev {
    left: 8px;
  }
  .gallery-arrow--next {
    right: 8px;
  }

  @media (min-width: 768px) {
    .gallery-arrow {
      width: 48px;
      height: 48px;
    }
    .gallery-arrow--prev {
      left: 12px;
    }
    .gallery-arrow--next {
      right: 12px;
    }
  }

  /* Dot styles */
  .gallery-dot[aria-selected='true'] {
    background-color: var(--color-neon);
  }
  .gallery-dot[aria-selected='false'] {
    background-color: color-mix(in srgb, var(--color-light-gray) 60%, transparent);
  }
  .gallery-dot[aria-selected='false']:hover {
    background-color: var(--color-light-gray);
  }
</style>
