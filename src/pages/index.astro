---
import { getCollection } from 'astro:content'

const cities = await getCollection('cities')
if (cities.length === 0) {
  throw new Error('Add at least one city under src/content/cities for the home redirect.')
}
const [target] = [...cities].sort((a, b) => a.id.localeCompare(b.id))
return Astro.redirect(`/${target.id}`)
---
