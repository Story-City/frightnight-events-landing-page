---
import Layout from '../layouts/Layout.astro'
import Content from '@component/Content.astro'
import Header from '@component/Header.astro'
import CTA from '@component/CTA.astro'
import { getCollection } from 'astro:content'
import { formatEventDateLabel } from '../lib/formatEventDate'

export async function getStaticPaths() {
  const cities = await getCollection('cities')
  return cities.map(item => ({
    params: { slug: item.id },
    props: { entry: item.data },
  }))
}

const { entry } = Astro.props

const city = String(entry.city ?? '').trim()
const cityTitleName = city || 'Event'
const locationLabel = city || 'LOCATION'
const eventDateLabel = formatEventDateLabel(entry.eventDate) || 'DATE'
const ticketSaleLink =
  typeof entry.ticketSaleLink === 'string' && entry.ticketSaleLink.trim() !== '' ? entry.ticketSaleLink : '#tickets'

const locationTime = cityTitleName === 'Phoenix' ? '4PM to 9PM' : '12PM to 7PM'
const description = `Brave a spooky ghost hunt through the streets of ${cityTitleName} in this interactive, suspense-filled multi-team event.
        Start anytime from ${locationTime}, follow eerie clues, and make choices that change your route and ending. Dress
        up, snap paranormal photos, and compete for prizes. Limited tickets available before they vanish into the night.`
---

<Layout title={`Frightnight · The Immersive ${cityTitleName} Event`} description={description}>
  <main class="bg-black min-h-screen overflow-hidden">
    <Header
      locationLabel={locationLabel}
      eventDateLabel={eventDateLabel}
      ticketHref={ticketSaleLink}
      cityName={cityTitleName}
    />
    <CTA
      originalTicketPrice={entry.originalTicketPrice}
      currentTicketPrice={entry.currentTicketPrice}
      ticketSaleLink={ticketSaleLink}
    />
    <Content cityName={cityTitleName} />
    <div class="text-center max-w-6xl mx-auto text-white py-8">
      <p class="text-lg lg:text-2xl leading-tight tracking-wide font-normal font-abeezee mb-4">
        <span class="font-medium">Story City Life Promise:</span> Life happens. If the weather or your plans change, your
        Frightnight pass is 100% transferable to any friend, any future Story City date, or any other city experience we offer.
      </p>
    </div>
  </main>
</Layout>
